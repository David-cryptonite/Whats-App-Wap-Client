# ============ SERVER ============
NODE_ENV=development
PORT=3500
RTSP_PORT=8554
APP_DATA_DIR=./data
AUTH_DB_PATH=./auth.db
SESSION_DB_PATH=./sessions.db

# ============ AUTHENTICATION ============
# Set to false/0/no/off to disable login (default: true)
AUTH_ENABLED=true

# ============ HTTPS / TLS ============
# Set to true/1/yes/on to enable HTTPS with auto Let's Encrypt certs
HTTPS_ENABLED=false
HTTPS_DOMAIN=example.com
HTTPS_EMAIL=admin@example.com
HTTPS_PORT=443
HTTPS_CERTS_DIR=./certs

# ============ WHATSAPP PAIRING ============
# If set, uses pairing code instead of QR. Digits only, with country code.
# If empty/unset, uses QR code (no prompt).
# Example: 391234567890
WA_PHONE_NUMBER=

# ============ WAP PUSH NOTIFICATIONS (NowSMS) ============
# Enable/disable WAP Push SI notifications for incoming messages
WAP_PUSH_ENABLED=false
# NowSMS gateway URL (e.g. http://your-nowsms-server:port/Send%20WAP%20Push%20Message.htm)
WAP_PUSH_BASE_URL=
# NowSMS Basic Auth header (base64 encoded user:pass, e.g. Basic dXNlcjpwYXNz)
WAP_PUSH_AUTH=
# Phone number to receive WAP Push notifications (empty = disabled)
WAP_PUSH_PHONE=
# Public URL of this server reachable by the phone (used in WAP Push SI links)
# Must NOT be 127.0.0.1 — the phone needs to reach this from the mobile network
# Example: http://your-public-ip:3500
WAP_SERVER_BASE=

# ============ MARKUP MODE ============
# Output format: wml (WAP 1.x), xhtml (WAP 2.0), html5 (modern browsers)
MARKUP_MODE=wml
# Upload page format: xhtml (basic form) or html5 (chunked upload)
UPLOAD_MARKUP_MODE=html5

# ============ WML SETTINGS ============
# WML timer units for auto-refresh (1 unit = 0.1s, 100 = 10s)
WML_REFRESH_TIMER_UNITS=100
